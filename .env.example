TG_BOT_TOKEN=
TG_CHAT_ID=
# LLM демо-модулей: DeepSeek — основной, OpenAI — резерв (см. lib/llm.ts)
DEEPSEEK_API_KEY=
OPENAI_API_KEY=
# опционально: переопределить URL/модель первого доступного провайдера
# LLM_BASE_URL=
# LLM_MODEL=
# Durable rate-limit (Upstash Redis). Без них лимиты работают только in-memory
# (слабее). Интеграция Upstash на Vercel добавляет эти переменные сама.
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=
# дневной потолок запросов к LLM на весь сайт (защита от накрутки счёта), по умолчанию 800
# LLM_DAILY_CAP=800
